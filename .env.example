# ════════════════════════════════════════════════════
#  JHD HOTEL & BAR — Copy this file to .env and fill in
#  NEVER commit your real .env file to GitHub
# ════════════════════════════════════════════════════

FLASK_ENV=development
SECRET_KEY=jhd-hotel-change-this-to-something-random-2025

# ── DATABASE ──────────────────────────────────────
# Local testing: leave as-is (uses SQLite)
# ⚠️ VERCEL DEPLOYMENT: Vercel has NO persistent file storage.
# You MUST use a hosted Postgres database — get one free from:
#   - Neon: neon.tech (recommended, free tier, instant setup)
#   - Supabase: supabase.com (free tier)
#   - Vercel Postgres (via Vercel dashboard → Storage)
# Then paste the connection string below, e.g.:
#   postgresql://user:pass@host.neon.tech/dbname
DATABASE_URL=sqlite:///jhd_hotel.db

# ── AUTOMATIC SEASONAL PRICING ───────────────────
# Price switches automatically based on guest's check-in date.
# Format: MM-DD:MM-DD,MM-DD:MM-DD (comma-separated ranges)
# Default below = Oct-Dec + Jan-Mar are PEAK season (Udaipur's main tourist season)
NORMAL_PRICE=4000
PEAK_PRICE=7000
PEAK_SEASON_RANGES=10-01:12-31,01-01:03-31

# Super Deluxe rooms cost this much extra per night on top of the
# Normal/Peak base price above (e.g. Normal=4000+1500=5500, Peak=7000+1500=8500)
SUPER_DELUXE_EXTRA=1500

# ── PAYPAL (Primary Payment Gateway) ──────────────
# developer.paypal.com → Apps & Credentials → Create App
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_SECRET_HERE
PAYPAL_MODE=sandbox

# ── RAZORPAY (Backup — UPI/Cards/NetBanking) ─────
# razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_HERE
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET_HERE

# ── EMAIL (Booking Confirmations) ────────────────
# Gmail → myaccount.google.com/security → App Passwords
MAIL_USERNAME=jhd.hotel.udaipur@gmail.com
MAIL_PASSWORD=xxxxxxxxxxxxxxxx

# ── ADMIN LOGIN (for /admin/login) ───────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password-here
